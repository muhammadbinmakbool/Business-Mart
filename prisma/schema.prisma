generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Party {
  id                 Int                 @id @default(autoincrement())
  name               String
  phoneNumber        String
  address            String?
  notes              String?
  partyType          String
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  intakeAdvances     IntakeAdvance[]
  intakeTransactions IntakeTransaction[]
  saleTransactions   SaleTransaction[]
  supplierInvoices   SupplierInvoice[]
}

model Product {
  id                 Int                 @id @default(autoincrement())
  name               String
  unitType           String
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  intakeTransactions IntakeTransaction[]
  saleItems          SaleItem[]
}

model IntakeTransaction {
  id           Int             @id @default(autoincrement())
  intakeNumber String          @unique
  entryDate    DateTime        @default(now())
  partyId      Int
  productId    Int
  bagCount     Int?
  grossWeight  Decimal         @db.Decimal(18, 2)
  rate         Decimal         @db.Decimal(18, 2)
  notes        String?
  status       String          @default("PENDING")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  advances     IntakeAdvance[]
  invoiceItems SupplierInvoiceItem[]
  party        Party           @relation(fields: [partyId], references: [id], onUpdate: NoAction)
  product      Product         @relation(fields: [productId], references: [id], onUpdate: NoAction)
}

model IntakeAdvance {
  id                  Int                @id @default(autoincrement())
  intakeTransactionId Int?
  partyId             Int
  amount              Decimal            @db.Decimal(18, 2)
  notes               String?
  supplierInvoiceId   Int?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  intakeTransaction   IntakeTransaction? @relation(fields: [intakeTransactionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  party               Party              @relation(fields: [partyId], references: [id], onUpdate: NoAction)
  supplierInvoice     SupplierInvoice?   @relation(fields: [supplierInvoiceId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model SaleTransaction {
  id           Int                     @id @default(autoincrement())
  saleNumber   String                  @unique
  entryDate    DateTime                @default(now())
  partyId      Int
  totalWeight  Decimal                 @db.Decimal(18, 2)
  baseAmount   Decimal                 @db.Decimal(18, 2)
  totalAdjustments Decimal             @db.Decimal(18, 2)
  finalAmount  Decimal                 @db.Decimal(18, 2)
  status       String                  @default("PENDING")
  notes        String?
  isDeleted    Boolean                 @default(false)
  changeLog    String?                 @db.NVarChar(Max)
  previousState String?                @db.NVarChar(Max)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  party        Party                   @relation(fields: [partyId], references: [id], onUpdate: NoAction)
  items        SaleItem[]
  adjustments  TransactionAdjustment[]
}

model SaleItem {
  id          Int             @id @default(autoincrement())
  saleId      Int
  productId   Int
  weight      Decimal         @db.Decimal(18, 2)
  rate        Decimal         @db.Decimal(18, 2)
  amount      Decimal         @db.Decimal(18, 2)
  sale        SaleTransaction @relation(fields: [saleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  product     Product         @relation(fields: [productId], references: [id], onUpdate: NoAction)
}

model TransactionAdjustment {
  id               Int             @id @default(autoincrement())
  saleId           Int
  adjustmentType   String          // Commission, Labour, Rent, Kaat, etc.
  method           String          // FIXED, PERCENTAGE, PER_WEIGHT
  value            Decimal         @db.Decimal(18, 2)
  calculatedAmount Decimal         @db.Decimal(18, 2)
  direction        String          @default("ADD") // ADD or SUBTRACT
  sale             SaleTransaction @relation(fields: [saleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model SupplierInvoice {
  id                 Int                  @id @default(autoincrement())
  invoiceNumber      String               @unique // SUP-XXXXXX
  partyId            Int
  entryDate          DateTime             @default(now())
  totalGrossValue    Decimal              @db.Decimal(18, 2)
  totalDeductions    Decimal              @db.Decimal(18, 2)
  totalAdvances      Decimal              @db.Decimal(18, 2)
  finalPayableAmount Decimal              @db.Decimal(18, 2)
  status             String               @default("PENDING") // PENDING | COMPLETED | SUPERSEDED
  isOutdated         Boolean              @default(false)
  version            Int                  @default(1)
  lastCalculatedAt   DateTime             @default(now())
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  party              Party                @relation(fields: [partyId], references: [id], onUpdate: NoAction)
  items              SupplierInvoiceItem[]
  advances           IntakeAdvance[]
}

model SupplierInvoiceItem {
  id                  Int               @id @default(autoincrement())
  supplierInvoiceId   Int
  intakeTransactionId Int
  weight              Decimal           @db.Decimal(18, 2) // SNAPSHOT
  rate                Decimal           @db.Decimal(18, 2) // SNAPSHOT
  amount              Decimal           @db.Decimal(18, 2) // SNAPSHOT
  invoice             SupplierInvoice   @relation(fields: [supplierInvoiceId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  intake              IntakeTransaction @relation(fields: [intakeTransactionId], references: [id], onUpdate: NoAction)
}
