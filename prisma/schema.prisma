generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Party {
  id                 Int                 @id @default(autoincrement())
  name               String
  phoneNumber        String
  address            String?
  notes              String?
  partyType          String
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  intakeAdvances     IntakeAdvance[]
  intakeTransactions IntakeTransaction[]
  saleTransactions   SaleTransaction[]
  supplierInvoices   SupplierInvoice[]
  supplierTracks     SalesTrack[]        @relation("SupplierTrack")
  buyerTracks        SalesTrack[]        @relation("BuyerTrack")
  payments           PartyPayment[]
  allocations        PartyPaymentAllocation[]

}

model Product {
  id                 Int                 @id @default(autoincrement())
  name               String
  category           String              @default("WEIGHT") // WEIGHT, LIQUID, QUANTITY
  primaryUnit        String              @default("KG")
  unitConversion     Decimal?            @db.Decimal(18, 4) // e.g. 1 BAG = 100 KG
  quantity           Decimal             @default(0) @db.Decimal(18, 2)
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  intakeTransactions IntakeTransaction[]
  saleItems          SaleItem[]
  salesTracks        SalesTrack[]
  rates              ProductRate[]
}


model IntakeTransaction {
  id           Int                   @id @default(autoincrement())
  intakeNumber String                @unique
  entryDate    DateTime              @default(now())
  partyId      Int
  productId    Int
  bagCount     Int?
  rate             Decimal?              @db.Decimal(18, 2)
  rateUnit         String                @default("KG") @db.NVarChar(50)
  grossWeight      Decimal               @db.Decimal(18, 2)
  unit             String                @default("KG")
  normalizedWeight Decimal               @default(0) @db.Decimal(18, 2)
  Bardana          Decimal?              @db.Decimal(18, 2)
  Khot             Decimal?              @db.Decimal(18, 2)
  netWeight        Decimal?              @db.Decimal(18, 2)
  remainingWeight  Decimal?              @db.Decimal(18, 2)
  notes            String?
  status           String                @default("PENDING")
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  advances     IntakeAdvance[]
  invoiceItems SupplierInvoiceItem[]
  salesTracks  SalesTrack[]


  party        Party                 @relation(fields: [partyId], references: [id], onUpdate: NoAction)
  product      Product               @relation(fields: [productId], references: [id], onUpdate: NoAction)
}

model IntakeAdvance {
  id                  Int                @id @default(autoincrement())
  intakeTransactionId Int?
  partyId             Int
  amount              Decimal            @db.Decimal(18, 2)
  notes               String?
  supplierInvoiceId   Int?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  intakeTransaction   IntakeTransaction? @relation(fields: [intakeTransactionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  party               Party              @relation(fields: [partyId], references: [id], onUpdate: NoAction)
  supplierInvoice     SupplierInvoice?   @relation(fields: [supplierInvoiceId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model SaleTransaction {
  id               Int                     @id @default(autoincrement())
  saleNumber       String                  @unique
  entryDate        DateTime                @default(now())
  partyId          Int
  totalWeight      Decimal                 @db.Decimal(18, 2)
  baseAmount       Decimal                 @db.Decimal(18, 2)
  totalAdjustments Decimal                 @db.Decimal(18, 2)
  finalAmount      Decimal                 @db.Decimal(18, 2)
  status           String                  @default("PENDING")
  paidAmount       Decimal                 @default(0) @db.Decimal(18, 2)
  paymentStatus    String                  @default("PENDING") // PENDING | PARTIAL | CLEARED
  notes            String?
  isDeleted        Boolean                 @default(false)
  changeLog        String?                 @db.NVarChar(Max)
  previousState    String?                 @db.NVarChar(Max)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  party            Party                   @relation(fields: [partyId], references: [id], onUpdate: NoAction)
  items            SaleItem[]
  adjustments      TransactionAdjustment[]
  salesTracks      SalesTrack[]

}

model SaleItem {
  id                  Int                @id @default(autoincrement())
  saleId              Int
  productId           Int
  weight              Decimal            @db.Decimal(18, 2)
  unit                String             @default("KG")
  normalizedWeight    Decimal            @default(0) @db.Decimal(18, 2)
  rate                Decimal            @db.Decimal(18, 2)
  rateUnit            String             @default("KG") // DEPRECATED: use unit
  amount              Decimal            @db.Decimal(18, 2)

  sale                SaleTransaction    @relation(fields: [saleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  product             Product            @relation(fields: [productId], references: [id], onUpdate: NoAction)
  salesTracks         SalesTrack[]
}

model SalesTrack {
  id                  Int       @id @default(autoincrement())

  saleTransactionId   Int?
  saleItemId          Int?
  intakeTransactionId Int?      @unique

  supplierPartyId     Int?
  buyerPartyId        Int?
  productId           Int?

  quantity            Decimal   @db.Decimal(18, 2)

  buyingRate          Decimal?  @db.Decimal(18, 2)
  sellingRate         Decimal?  @db.Decimal(18, 2)

  netWeight           Decimal?  @db.Decimal(18, 2)
  baseAmount          Decimal?  @db.Decimal(18, 2)

  isBilled            Boolean   @default(false)
  isSettled           Boolean   @default(false)

  notes               String?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt


  saleTransaction     SaleTransaction?   @relation(fields: [saleTransactionId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  saleItem            SaleItem?          @relation(fields: [saleItemId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  intakeTransaction   IntakeTransaction? @relation(fields: [intakeTransactionId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  supplier            Party?             @relation("SupplierTrack", fields: [supplierPartyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  buyer               Party?             @relation("BuyerTrack", fields: [buyerPartyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  product             Product?           @relation(fields: [productId], references: [id], onUpdate: NoAction)
}




model TransactionAdjustment {
  id               Int             @id @default(autoincrement())
  saleId           Int
  adjustmentType   String // Commission, Labour, Rent, Kaat, etc.
  method           String // FIXED, PERCENTAGE, PER_WEIGHT
  value            Decimal         @db.Decimal(18, 2)
  calculatedAmount Decimal         @db.Decimal(18, 2)
  direction        String          @default("ADD") // ADD or SUBTRACT
  unit             String?         @db.NVarChar(50)
  sale             SaleTransaction @relation(fields: [saleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model SupplierInvoice {
  id                 Int                         @id @default(autoincrement())
  invoiceNumber      String                      @unique // SUP-XXXXXX
  partyId            Int
  entryDate          DateTime                    @default(now())
  totalGrossValue    Decimal                     @db.Decimal(18, 2)
  totalDeductions    Decimal                     @db.Decimal(18, 2)
  totalAdvances      Decimal                     @db.Decimal(18, 2)
  finalPayableAmount Decimal                     @db.Decimal(18, 2)
  status             String                      @default("PENDING") // PENDING | COMPLETED | SUPERSEDED
  paidAmount         Decimal                     @default(0) @db.Decimal(18, 2)
  paymentStatus      String                      @default("PENDING") // PENDING | PARTIAL | CLEARED
  isOutdated         Boolean                     @default(false)
  version            Int                         @default(1)
  lastCalculatedAt   DateTime                    @default(now())
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt
  party              Party                       @relation(fields: [partyId], references: [id], onUpdate: NoAction)
  items              SupplierInvoiceItem[]
  advances           IntakeAdvance[]
}

model SupplierInvoiceAdjustment {
  id                    Int                 @id @default(autoincrement())
  supplierInvoiceItemId Int
  adjustmentType        String              // Commission, Labour, Rent, Kaat, etc.
  method                String              // FIXED, PERCENTAGE, PER_WEIGHT
  value                 Decimal             @db.Decimal(18, 2)
  calculatedAmount      Decimal             @db.Decimal(18, 2)
  direction             String              @default("ADD") // ADD or SUBTRACT
  unit                  String?             @db.NVarChar(50)
  item                  SupplierInvoiceItem @relation(fields: [supplierInvoiceItemId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model SupplierInvoiceItem {
  id                  Int                         @id @default(autoincrement())
  supplierInvoiceId   Int
  intakeTransactionId Int
  weight              Decimal                     @db.Decimal(18, 2) // SNAPSHOT
  rate                Decimal                     @db.Decimal(18, 2) // SNAPSHOT
  amount              Decimal                     @db.Decimal(18, 2) // SNAPSHOT
  invoice             SupplierInvoice             @relation(fields: [supplierInvoiceId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  intake              IntakeTransaction           @relation(fields: [intakeTransactionId], references: [id], onUpdate: NoAction)
  adjustments         SupplierInvoiceAdjustment[]
}

model LedgerSession {
  id                   Int      @id @default(autoincrement())
  title                String
  startDate            DateTime
  endDate              DateTime
  supplierTotal        Decimal  @db.Decimal(18, 2)
  buyerTotal           Decimal  @db.Decimal(18, 2)
  difference           Decimal  @db.Decimal(18, 2)
  supplierInvoiceCount Int      @default(0)
  buyerInvoiceCount    Int      @default(0)
  status               String   @default("OPEN") // OPEN | LOCKED
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model ProductRate {
  id        Int      @id @default(autoincrement())
  productId Int
  rate      Decimal  @db.Decimal(18, 2)
  unit      String   @db.NVarChar(50)
  date      DateTime @default(now())
  source    String?  @db.NVarChar(100) // e.g. MANUAL, MARKET, WHATSAPP
  isDeleted Boolean  @default(false)
  notes     String?  @db.NVarChar(Max)
  createdBy String?  @db.NVarChar(100) // Operator placeholder
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model ActivityLog {
  id          Int      @id @default(autoincrement())
  entityType  String   @db.NVarChar(100) // PRODUCT, PARTY, INTAKE, SALE, SETTLEMENT, SYSTEM
  entityId    Int?
  action      String   @db.NVarChar(100) // CREATED, UPDATED, DELETED, COMPLETED, CANCELLED, ARCHIVED, SUPERSEDED, SOLD
  description String?  @db.NVarChar(Max)
  userId      Int      @default(0)
  userName    String?  @db.NVarChar(255)
  meta        String?  @db.NVarChar(Max)
  createdAt   DateTime @default(now())

  @@index([entityType])
  @@index([action])
  @@index([createdAt])
}

model PartyPayment {
  id            Int                      @id @default(autoincrement())
  partyId       Int
  paymentNumber String                   @unique
  paymentType   String                   // CASH_IN, CASH_OUT
  paymentMethod String?                  // CASH, BANK, JAZZCASH, EASYPAISA, CHEQUE
  amount        Decimal                  @db.Decimal(18, 2)
  sourceType    String                   @default("MANUAL") // MANUAL, DIRECT_SALE, DIRECT_SETTLEMENT, SYSTEM
  sourceId      Int?
  status        String                   @default("ACTIVE") // ACTIVE, VOIDED, REVERSED
  entryDate     DateTime                 @default(now())
  notes         String?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  party         Party                    @relation(fields: [partyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  allocations   PartyPaymentAllocation[]

  @@index([partyId])
  @@index([paymentNumber])
  @@index([createdAt])
}

model PartyPaymentAllocation {
  id              Int          @id @default(autoincrement())
  partyId         Int
  paymentId       Int
  referenceType   String       // SALE, SETTLEMENT
  referenceId     Int
  allocatedAmount Decimal      @db.Decimal(18, 2)
  createdAt       DateTime     @default(now())
  party           Party        @relation(fields: [partyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  payment         PartyPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([partyId])
  @@index([referenceType, referenceId])
}


